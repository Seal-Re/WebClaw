# Tavily Search (required)
TAVILY_API_KEY=tvly-...

# Qdrant vector database (required)
QDRANT_URL=http://127.0.0.1:6333
RAG_COLLECTION=kb_main

# LLM (required, unless OPENCLAW_SKIP_LLM=1)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Embedding service (required; falls back to OPENAI_API_KEY if not set)
EMBED_BASE_URL=https://api.vectorengine.ai/v1
VECTORENGINE_API_KEY=sk-...
RAG_INGEST_EMBED_MODEL=text-embedding-3-large

# Tencent COS (optional, for backup storage)
# COS_SECRET_ID=
# COS_SECRET_KEY=
# COS_BUCKET=
# COS_REGION=ap-shanghai
# COS_BASE_PATH=rag-kb

# Behaviour flags
# OPENCLAW_SKIP_LLM=1    # Skip LLM refinement, ingest raw content only
